{
  "compilerOptions": {
    "baseUrl": "./src",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "useDefineForClassFields": false,
    "types": ["obsidian-typings"],
    "lib": [
      "DOM",
      "ES2022",
      "DOM.Iterable"
    ]
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "src/legacy/*.ts"
  ]
}
