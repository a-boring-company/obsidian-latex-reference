{
  "includes": [
    "**/*.{ts,js,mjs,json,md}"
  ],
  "excludes": [
    "node_modules",
    "main.js",
    "dist",
    "docs",
    "styles.css",
    "*.css.map",
    "package-lock.json"
  ],
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.93.0.wasm",
    "https://plugins.dprint.dev/json-0.19.3.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm"
  ],
  "typescript": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": "always",
    "quoteStyle": "alwaysSingle",
    "trailingCommas": "always"
  },
  "json": {
    "indentWidth": 2
  },
  "markdown": {
    "lineWidth": 80
  }
}
